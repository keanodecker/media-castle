# SMTP-Konfiguration für das Kontaktformular
# Kopieren Sie diese Datei zu .env.local und tragen Sie Ihre Daten ein

# Für Gmail: smtp.gmail.com (App-Passwort erforderlich: Google-Konto → Sicherheit → App-Passwörter)
# Für andere Anbieter: entsprechenden SMTP-Server verwenden
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ihre-email@gmail.com
SMTP_PASS=ihr-app-passwort
