# Resend API Key für das Kontaktformular
# Konto erstellen auf resend.com → API Keys → Key erstellen
# Domain media-castle.com in Resend verifizieren (DNS-Eintrag)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 Measurement ID
# In GA4 → Verwaltung → Datenstreams → Web → "G-XXXXXXXXXX" kopieren
# Cookie-Banner steuert Consent Mode v2 automatisch.
# Optional: leer lassen, dann wird kein Tracking-Script geladen.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
